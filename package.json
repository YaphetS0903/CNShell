{
  "name": "cnshell",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:ipc && tsc -b && vite build",
    "build:freerdp": "./scripts/build-freerdp-sidecar.sh",
    "build:mosh": "./scripts/build-mosh-sidecar.sh",
    "build:desktop": "npm run build:freerdp && npm run build:mosh && npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:protocol": "./scripts/protocol-test.sh",
    "test:pty-fixture": "./scripts/pty-fixture-test.sh",
    "test:soak": "./scripts/soak-test.sh",
    "test:relay": "cargo test --manifest-path services/team-relay/Cargo.toml",
    "test:relay-ops": "./services/team-relay/scripts/ops-test.sh",
    "check:relay": "cargo clippy --manifest-path services/team-relay/Cargo.toml --all-targets -- -D warnings && npm run test:relay && npm run test:relay-ops",
    "generate:ipc": "node scripts/generate-ipc-types.mjs",
    "check:ipc": "node scripts/generate-ipc-types.mjs --check",
    "lint": "npm run check:ipc && eslint . --max-warnings=0",
    "tauri": "tauri",
    "check": "npm run lint && npm run test && npm run build && cargo test --manifest-path src-tauri/Cargo.toml && npm run check:relay"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "uplot": "^1.6.32",
    "yaml": "^2.9.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.8.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
